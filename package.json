{
  "name": "dgii-ecf-engine",
  "version": "1.0.0",
  "description": "Standalone engine to generate, sign, validate and submit DGII e-CF / RFCE electronic fiscal documents (Dominican Republic).",
  "main": "dist/api.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate-all": "ts-node src/cli.ts",
    "build-ri": "ts-node src/buildRIs.ts",
    "serve": "ts-node src/api.ts",
    "start": "node dist/api.js"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "express": "^4.19.2",
    "fflate": "^0.8.3",
    "iconv-lite": "^0.7.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "node-forge": "^1.3.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "xml-crypto": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
